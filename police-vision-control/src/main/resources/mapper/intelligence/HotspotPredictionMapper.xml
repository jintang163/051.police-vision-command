<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.police.vision.control.mapper.intelligence.HotspotPredictionMapper">

    <resultMap id="caseDataMap" type="java.util.HashMap">
        <result column="grid_code" property="grid_code" jdbcType="VARCHAR"/>
        <result column="case_time" property="case_time" jdbcType="TIMESTAMP"/>
        <result column="case_count" property="case_count" jdbcType="INTEGER"/>
    </resultMap>

    <select id="selectHistoryCaseData" resultMap="caseDataMap">
        SELECT
            grid_code,
            case_time
        FROM police_case_info
        WHERE 1=1
          AND case_time &gt;= #{startTime}
          AND case_time &lt; #{endTime}
          <if test="caseType != null and caseType != ''">
              AND case_type = #{caseType}
          </if>
          <if test="areaCode != null and areaCode != ''">
              AND area_code = #{areaCode}
          </if>
        ORDER BY case_time ASC
    </select>

    <select id="selectActualCaseData" resultMap="caseDataMap">
        SELECT
            grid_code,
            COUNT(1) AS case_count
        FROM police_case_info
        WHERE 1=1
          AND case_time &gt;= #{startTime}
          AND case_time &lt; #{endTime}
          <if test="caseType != null and caseType != ''">
              AND case_type = #{caseType}
          </if>
          <if test="areaCode != null and areaCode != ''">
              AND area_code = #{areaCode}
          </if>
        GROUP BY grid_code
    </select>

</mapper>
