package com.police.vision.alarm.rules;

import com.police.vision.alarm.entity.DispatchContext;
import com.police.vision.alarm.entity.PoliceOfficer;
import com.police.vision.common.util.GpsUtil;
import java.util.ArrayList;
import java.util.Comparator;
import java.util.List;
import java.util.stream.Collectors;

dialect "mvel"

rule "火警派单规则"
    salience 100
    when
        $context : DispatchContext(alarmType == 4)
    then
        $context.setPriority(1);
        $context.setRequiredOfficerCount(2);
        $context.setMaxDistance(3.0);
        $context.setNeedFireTruck(true);
        $context.setDispatchSuggestion("火警，派最近3公里内2名以上警力+消防车");

        List<PoliceOfficer> available = $context.getAvailableOfficers();
        if (available != null && !available.isEmpty()) {
            List<PoliceOfficer> filtered = available.stream()
                .filter(o -> o.getStatus() == 1)
                .peek(o -> o.setDistance(GpsUtil.getDistance(
                    $context.getLongitude(), $context.getLatitude(),
                    o.getLongitude(), o.getLatitude())))
                .filter(o -> o.getDistance() <= $context.getMaxDistance())
                .sorted(Comparator.comparingDouble(PoliceOfficer::getDistance))
                .limit($context.getRequiredOfficerCount())
                .collect(Collectors.toList());
            $context.getRecommendedOfficers().addAll(filtered);
        }
end

